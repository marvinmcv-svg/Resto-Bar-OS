{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd apps/api && npx prisma generate && cd ../.. && npm run build",
    "startCommand": "cd apps/api && npm run start:prod"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "api": {
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd apps/api && npx prisma generate && npm run build",
        "startCommand": "cd apps/api && npm run start:prod"
      }
    },
    "web": {
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd apps/web && npm run build",
        "startCommand": "cd apps/web && npm run start"
      },
      "rootDirectory": "apps/web"
    }
  }
}