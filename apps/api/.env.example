DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurant_os
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-must-be-at-least-256-bits
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
APP_VERSION=1.0.0
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (nodemailer — leave blank to disable sending, service will log instead)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="RestaurantOS <noreply@restaurantos.com>"

# Redis (for BullMQ queues — required when REDIS_URL not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=